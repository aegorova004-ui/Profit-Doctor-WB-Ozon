# Local PostgreSQL example. Never commit a real password or production URL.
DATABASE_URL="postgresql://profit_doctor:change-me@localhost:5432/profit_doctor?schema=public"

# Auth email/OTP delivery. Keep real keys only in local env or deployment secrets.
# Supported values are documented in docs/auth-email-provider-options.md.
AUTH_EMAIL_PROVIDER="disabled"
AUTH_EMAIL_FROM="Profit Doctor <login@example.com>"
AUTH_EMAIL_API_KEY=""
